# Le Jibé — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── Hetzner (infrastructure management only) ──────────────────────
HETZNER_API_KEY=
HETZNER_SERVER_IP=178.104.38.111

# ── Database ──────────────────────────────────────────────────────
POSTGRES_DB=lejibe
POSTGRES_USER=lejibe
POSTGRES_PASSWORD=change_me_in_production

# ── Backend ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://lejibe:change_me_in_production@postgres:5432/lejibe

# Admin panel token — generate with: openssl rand -hex 32
ADMIN_TOKEN=change_me_in_production

# CORS: comma-separated origins allowed to call the API
# Local dev: http://localhost:5173
# Production: https://lejibe.fr
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────────
# In production, frontend calls /api/* via nginx (same origin — leave blank)
# In local dev, set to http://localhost:8000
PUBLIC_API_URL=

# ── nginx / SSL ───────────────────────────────────────────────────
DOMAIN=lejibe.fr
